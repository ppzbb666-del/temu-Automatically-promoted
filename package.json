{
  "name": "temu-ai-ops",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "node scripts/check-environment.mjs",
    "start": "npm run dev",
    "dev": "concurrently --names \"server,dash\" --prefix-colors \"cyan,magenta\" --kill-others-on-fail \"npm:dev:server\" \"npm:dev:dashboard\"",
    "dev:dashboard": "npm run dev --workspace @temu-ai-ops/dashboard",
    "dev:server": "npm run dev --workspace @temu-ai-ops/server",
    "build": "npm run build --workspaces --if-present",
    "build:desktop": "npm run build --workspace @temu-ai-ops/desktop",
    "dist:windows": "npm run dist --workspace @temu-ai-ops/desktop",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "test:smoke": "npm run test:smoke --workspace @temu-ai-ops/server"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "playwright": "^1.59.1"
  }
}
