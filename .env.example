# 内容生成大模型配置模板 —— 复制为 .env 并填入真实值（.env 已被 gitignore，不入库）。
# 走 OpenAI 兼容的 /chat/completions；DeepSeek / 通义千问 / OpenAI / 中转站 / 本地 vLLM 通用。

# 模型 API key。不设 = 禁用大模型，纯规则化文案生成（不影响主流程）。
LLM_API_KEY=

# OpenAI 兼容基址。留空默认 https://api.openai.com/v1
# 例：DeepSeek → https://api.deepseek.com/v1
LLM_BASE_URL=

# 模型名。留空默认 gpt-4o-mini
# 例：deepseek-chat / claude-sonnet-5 / gpt-4o-mini
LLM_MODEL=

# 单次调用超时（毫秒）。留空默认 20000
LLM_TIMEOUT_MS=

# 采样温度（可选）。默认不发送 —— 较新模型（如 claude-sonnet-5）对该字段报 400，
# 仅当你的模型明确需要时才填（如 0.4）。
# LLM_TEMPERATURE=
